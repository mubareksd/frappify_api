FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
MAIL_SERVER="mail_server"
MAIL_PORT=465
MAIL_USE_TLS=True
MAIL_USE_SSL=True
MAIL_USERNAME="yourmail@mail.com"
MAIL_PASSWORD="password"
MAIL_DEFAULT_SENDER="yourmail@mail.com"
DATABASE_URL=postgresql+psycopg2://frappify:frappify@localhost:5432/frappify
TEST_DATABASE_URL=sqlite:///:memory:
EMAIL_VERIFICATION_SALT=email-verification
EMAIL_VERIFICATION_MAX_AGE=86400
PASSWORD_RESET_SALT=password-reset
PASSWORD_RESET_MAX_AGE=3600
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_KEY_STRATEGY=ip
RATE_LIMIT_EXEMPT_PATHS=/api/health
WEBSOCKET_PROXY_ENABLED=True
WEBSOCKET_PROXY_TIMEOUT_SECONDS=30
